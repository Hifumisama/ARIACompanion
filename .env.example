# ARIA Companion — Configuration

# Ports
ORCHESTRATOR_PORT=4545
BRAIN_PORT=8080
FRONTEND_PORT=5173

# llama.cpp — Model
# Name of the GGUF file in brain/models/
MODEL_FILE=model.gguf
# Number of layers to offload to GPU (0 = CPU only)
GPU_LAYERS=0
# Context window size
CONTEXT_SIZE=4096
# Number of CPU threads
THREADS=4

# Memory
# Number of messages before generating a summary
SUMMARY_INTERVAL=10

# STT (Whisper)
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
WHISPER_LANGUAGE=fr

# TTS (Piper)
# Download a voice from https://huggingface.co/rhasspy/piper-voices
# Place .onnx + .onnx.json in models/piper/
