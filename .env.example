# ARIA Companion — Configuration Docker

# ── Ports (décalés pour éviter les conflits avec les services locaux) ──
OLLAMA_PORT=11435
VOICE_PORT=8011
FORGE_BACKEND_PORT=8012
FORGE_FRONTEND_PORT=5184
ORCHESTRATOR_PORT=4555
FRONTEND_PORT=5183

# ── Ollama ──
# Modèle à télécharger au démarrage
OLLAMA_MODEL=llama3.2

# ── STT (Whisper) ──
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
WHISPER_LANGUAGE=fr

# ── Orchestrator ──
# ID du personnage actif (laisser vide pour le défaut)
ACTIVE_CHARACTER_ID=
# Mots-clés d'interruption (séparés par des virgules)
INTERRUPTION_KEYWORDS=stop,arrête,tais-toi
# Taille des chunks TTS en bytes
TTS_CHUNK_SIZE=16384
